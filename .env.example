# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys.

# --- Browser-exposed (safe to ship) ---
# Anything prefixed VITE_ is bundled into the frontend. Only the Supabase
# anon key + URL belong here; Row-Level Security protects your data.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Server-only (NEVER prefix with VITE_, only read inside /api functions) ---
SUPABASE_SERVICE_ROLE_KEY=
STRIPE_SECRET_KEY=
ANTHROPIC_API_KEY=
